# ──────────────────────────────────────────────────────────────
# Stock-Alpha 환경변수 예시 — 실제 값은 .env(.local)에 두고 커밋 금지
# ──────────────────────────────────────────────────────────────

# ── Supabase (데이터 스토어 / Auth) ──
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key   # 서버/워커 전용. 절대 클라이언트 노출 금지
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Claude / LLM (리포트·내러티브) ──
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_REPORT_MODEL=claude-opus-4-8
CLAUDE_SUMMARY_MODEL=claude-sonnet-4-6

# ── 데이터 소스 (공개·저가 우선) ──
DART_API_KEY=                 # 국내 전자공시 OpenDART
FRED_API_KEY=                 # 미국 매크로
ECOS_API_KEY=                 # 한국은행 경제통계
FMP_API_KEY=                  # Financial Modeling Prep (미국 재무·시세)
# yfinance / pykrx / SEC EDGAR 는 키 불필요

# ── 한국투자증권 OpenAPI (실시간 틱·호가 / Phase 3 체결) ──
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ENV=paper                 # paper(모의) | real(실거래)

# ── 결제 (택1: 진행 중 확정) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# TOSS_SECRET_KEY=

# ── 보안 (Phase 3 broker 키 암호화) ──
KMS_KEY_ID=                   # 클라우드 KMS 키 식별자

# ── 엔진 런타임 ──
ENGINE_ENV=development        # development | production
ENGINE_LOG_LEVEL=INFO
