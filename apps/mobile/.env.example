# apps/mobile 전용 환경변수 — 웹과 동일한 Supabase 백엔드를 공유한다.
# 실제 값은 .env.local 에 두고 커밋 금지. (EXPO_PUBLIC_* 만 클라이언트 노출)
# 값은 apps/web/.env.local 의 NEXT_PUBLIC_SUPABASE_* 와 동일.
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# service_role 키·broker 키는 절대 앱에 넣지 않는다 (서버/워커 전용).
